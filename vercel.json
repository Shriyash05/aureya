{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",

  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}